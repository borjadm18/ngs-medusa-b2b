{
  "name": "b2b-starter",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "sync:client-profile": "node scripts/sync-client-profile.mjs",
    "test": "turbo run test",
    "test:integration:http": "turbo run test:integration:http",
    "test:integration:modules": "turbo run test:integration:modules",
    "test:unit": "turbo run test:unit",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@medusajs/eslint-plugin": "2.16.0",
    "eslint": "^9.13.0",
    "jiti": "^2.7.0",
    "turbo": "^2.3.3"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.0.5",
      "@types/react-dom": "19.0.5"
    }
  }
}
